PORT=4173

# Paid provider APIs. Create keys on the provider dashboards and keep them server-side only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

XAI_API_KEY=
XAI_MODEL=grok-4.3

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.6

# Z.ai currently offers free model options such as glm-4.7-flash.
ZAI_API_KEY=
ZAI_MODEL=glm-4.7-flash

# Use OpenRouter for free/rate-limited model variants and Meta Llama routing.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
META_MODEL=meta-llama/llama-3.2-3b-instruct:free